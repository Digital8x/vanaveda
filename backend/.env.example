# ============================================================
# Codename Green Gold Nerul - Environment Variables (Example)
# ============================================================

NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=8h

# SMTP
SMTP_HOST=your_smtp_host
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=Your From Name
SMTP_FROM_EMAIL=leads@yourdomain.com
ADMIN_EMAILS=admin@yourdomain.com

# Project
PROJECT_NAME=Codename Green Gold Nerul
SITE_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=100

# Admin
ADMIN_SESSION_SECRET=your_admin_session_secret
